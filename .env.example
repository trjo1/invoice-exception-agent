# =============================================================================
# Agent 1 — P2P Exception Orchestrator — environment template
# =============================================================================
# Copy to .env and fill in. NEVER commit .env to git.

# -----------------------------------------------------------------------------
# MODE
# -----------------------------------------------------------------------------
# CORPUS_MODE controls how synthetic test data is generated.
#   subscription = use Claude.ai / ChatGPT subscriptions; prompts written to
#                  scripts/subscription_workflow/prompts/ for manual paste.
#                  No API key needed. CURRENT DEFAULT.
#   api          = use OpenRouter (or direct provider) API. Requires
#                  OPENROUTER_API_KEY below.
CORPUS_MODE=subscription

# -----------------------------------------------------------------------------
# Primary model access — OpenRouter (optional in subscription mode)
# -----------------------------------------------------------------------------
# Get one at: https://openrouter.ai/keys
# Only required for: agent runtime calls (the actual P2P agent inference,
# not corpus generation) and for switching CORPUS_MODE=api later.
OPENROUTER_API_KEY=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# Direct provider API keys (optional — only when overriding OpenRouter)
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# -----------------------------------------------------------------------------
# Closed-model fallback keys (optional — only for per-task overrides in prod)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Per-task model override (optional)
# -----------------------------------------------------------------------------
# Set any of these to override the default model for that task.
# Format: provider/model-id (must be in config/models.yaml).
# MODEL_OVERRIDE_classification=anthropic/claude-sonnet-4
# MODEL_OVERRIDE_decision_support=anthropic/claude-sonnet-4
# MODEL_OVERRIDE_drafting=anthropic/claude-haiku-4

# -----------------------------------------------------------------------------
# Cost ceilings
# -----------------------------------------------------------------------------
# Per-call soft alert threshold (warns above this)
LLM_CALL_SOFT_CEILING_USD=0.10
# Per-call hard ceiling (blocks above this)
LLM_CALL_HARD_CEILING_USD=1.00
# Per-task budget (one exception end-to-end)
LLM_TASK_BUDGET_USD=0.50

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/p2p_agent

# -----------------------------------------------------------------------------
# ERP sandbox connections (optional — only when integration tests run)
# -----------------------------------------------------------------------------
# SAP S/4HANA Cloud trial (PRIMARY ERP sandbox — per test_corpus_design §6)
# Get these from BTP cockpit → Security → Service instances → service key.
# See docs/sap_sandbox_setup.md for the full step-by-step.
SAP_BASE_URL=
SAP_TOKEN_URL=
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=

# Microsoft Dynamics 365 Finance trial
DYNAMICS_TENANT_ID=
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=

# ServiceNow developer instance
SERVICENOW_INSTANCE_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# SAP Ariba sandbox
ARIBA_REALM=
ARIBA_API_KEY=

# -----------------------------------------------------------------------------
# Email integrations (optional — only when supplier-comm tests run)
# -----------------------------------------------------------------------------
# Microsoft Graph
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Gmail
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Logging + observability
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LLM_CALL_LOG_PATH=logs/llm_calls.jsonl
